# Resend API key — get yours at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# "From" address — must be a verified domain in Resend
RESEND_FROM=Praesidio <hello@praesidio.live>

# Admin API key — protects /api/admin/* endpoints (pick any strong secret)
ADMIN_API_KEY=your-secret-admin-key

# SQLite database file path (defaults to waitlist.db in working directory)
WAITLIST_DB=waitlist.db

# Server port (defaults to 8080)
PORT=8080
